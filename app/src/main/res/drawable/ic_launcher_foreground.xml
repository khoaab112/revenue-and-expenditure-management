<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Safe area is center 66dp: from x=21, y=21 to x=87, y=87 -->

    <!-- 1. STYLISH GRADIENT CIRCLE OUTLINE WITH A GAP -->
    <!-- Center (54, 54), Radius 34. Start at top-right (83.4, 37) and arc to (71, 24.6) clockwise -->
    <path
        android:pathData="M 83.4,37 A 34,34 0 1,1 71,24.6"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:fillColor="#00000000" >
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="20"
                android:startY="20"
                android:endX="88"
                android:endY="88"
                android:type="linear">
                <item android:color="#2196F3" android:offset="0.0" />
                <item android:color="#00BCD4" android:offset="0.5" />
                <item android:color="#00E676" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 2. BAR CHART BARS IN GREEN/TEAL GRADIENT -->
    <!-- Rising behind the top of the wallet (y = 46) -->
    <!-- Bar 1 (left) -->
    <path
        android:pathData="M 44,48 L 44,40.5 A 2.2,2.2 0 0,1 48.4,40.5 L 48.4,48 Z" >
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="44"
                android:startY="38"
                android:endX="48.4"
                android:endY="48"
                android:type="linear">
                <item android:color="#4AF7C5" android:offset="0.0" />
                <item android:color="#08C29E" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bar 2 (middle) -->
    <path
        android:pathData="M 51.5,48 L 51.5,34.5 A 2.2,2.2 0 0,1 55.9,34.5 L 55.9,48 Z" >
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="51.5"
                android:startY="32"
                android:endX="55.9"
                android:endY="48"
                android:type="linear">
                <item android:color="#4AF7C5" android:offset="0.0" />
                <item android:color="#08C29E" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bar 3 (right) -->
    <path
        android:pathData="M 59,48 L 59,28.5 A 2.2,2.2 0 0,1 63.4,28.5 L 63.4,48 Z" >
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="59"
                android:startY="26"
                android:endX="63.4"
                android:endY="48"
                android:type="linear">
                <item android:color="#4AF7C5" android:offset="0.0" />
                <item android:color="#08C29E" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 3. BLUE GRADIENT WALLET BODY -->
    <path
        android:pathData="M 41,46 L 69,46 A 4,4 0 0,1 73,50 L 73,69 A 4,4 0 0,1 69,73 L 41,73 A 4,4 0 0,1 37,69 L 37,50 A 4,4 0 0,1 41,46 Z" >
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="37"
                android:startY="46"
                android:endX="73"
                android:endY="73"
                android:type="linear">
                <item android:color="#64B5F6" android:offset="0.0" />
                <item android:color="#2196F3" android:offset="0.4" />
                <item android:color="#1976D2" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 4. WALLET FLAP WITH BUTTON -->
    <!-- Placed on the right side of the wallet -->
    <path
        android:pathData="M 64,55 L 72,55 A 2.5,2.5 0 0,1 74.5,57.5 L 74.5,61.5 A 2.5,2.5 0 0,1 72,64 L 64,64 Z" >
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="64"
                android:startY="55"
                android:endX="74.5"
                android:endY="64"
                android:type="linear">
                <item android:color="#1976D2" android:offset="0.0" />
                <item android:color="#0D47A1" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- Card Flap white dot button -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 68.5,59.5 A 1.8,1.8 0 1,1 68.5,59.49 Z" />

    <!-- 5. COIN BACKGROUND WHITE SHIELD (separates green coin from blue wallet) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 40,65 A 11,11 0 1,1 40,64.99 Z" />

    <!-- 6. COIN LAYER (Vibrant Minty Green circular coin overlay on bottom-left) -->
    <path
        android:pathData="M 40,65 A 10,10 0 1,1 40,64.99 Z" >
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="30"
                android:startY="55"
                android:endX="50"
                android:endY="75"
                android:type="linear">
                <item android:color="#1DE9B6" android:offset="0.0" />
                <item android:color="#00D09B" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 7. COIN DOLLAR SIGN $ INTERIOR (Clean, thick white dollar symbol) -->
    <!-- Vertical strike line -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:pathData="M 40,59.5 L 40,70.5" />
    <!-- 'S' curve outline -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 42.5,62 C 42,61 38,61.5 38.5,64.5 C 39,67.5 41,66.5 41.5,69 C 42,71 38.5,70.5 37.5,69.5" />

</vector>
